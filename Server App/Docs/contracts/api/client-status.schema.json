{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pummelchen.local/schemas/client-status.schema.json",
  "title": "Pummelchen Client Status Report",
  "type": "object",
  "required": [
    "client_id",
    "reported_at",
    "installed_release_id",
    "target_release_id",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "client_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "reported_at": {
      "type": "string",
      "format": "date-time"
    },
    "installed_release_id": {
      "type": ["string", "null"]
    },
    "target_release_id": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": [
        "registered",
        "heartbeat",
        "synced",
        "outdated",
        "stale_release",
        "downloading",
        "needs_defaults_repair",
        "failed_checksum",
        "error",
        "offline",
        "blocked_minecraft_running"
      ]
    },
    "manifest_entries": {
      "type": "integer",
      "minimum": 0
    },
    "changed_files": {
      "type": "integer",
      "minimum": 0
    },
    "last_error": {
      "type": ["string", "null"]
    },
    "message": {
      "type": ["string", "null"]
    },
    "os_summary": {
      "type": ["string", "null"]
    },
    "arch": {
      "type": ["string", "null"]
    }
  }
}
