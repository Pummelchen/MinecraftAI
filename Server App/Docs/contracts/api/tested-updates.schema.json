{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pummelchen.local/schemas/tested-updates.schema.json",
  "title": "Pummelchen Tested Updates Feed",
  "type": "object",
  "required": ["generated_at", "cutoff_days", "total_entries", "updates"],
  "additionalProperties": true,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "cutoff_days": {
      "type": "integer",
      "minimum": 0
    },
    "total_entries": {
      "type": "integer",
      "minimum": 0
    },
    "updates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "title", "event_type", "status"],
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string"},
          "source": {"type": "string"},
          "title": {"type": "string"},
          "event_type": {"type": "string"},
          "status": {"type": "string"},
          "tested_at": {"type": ["string", "null"]},
          "tested_at_display": {"type": ["string", "null"]},
          "old_file": {"type": ["string", "null"]},
          "new_file": {"type": ["string", "null"]},
          "source_url": {"type": ["string", "null"]},
          "test_label": {"type": ["string", "null"]},
          "notes": {"type": ["string", "null"]},
          "mod_id": {"type": ["integer", "null"]}
        }
      }
    }
  }
}
